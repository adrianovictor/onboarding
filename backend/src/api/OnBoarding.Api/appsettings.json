{
  "Logging": {
    "Options": {
      "Environment": "Production"
    },
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information",
      "System": "Warning"
    }
  },
  "Graylog": {
    "Host": "",
    "Port": 12201,
    "TransportType": ""
  },
  "ApiConfiguration": {
    "Name": "OnBoarding.Api",
